  "private": true,
  "scripts": {
    "build": "yarn db:generate && next build",
    "build-storybook": "storybook build",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "chromatic": "chromatic --exit-zero-on-changes",
    "datasets:merge": "node scripts/merge-datasets.js",
    "db:generate": "zen generate",
    "db:migrate": "zen migrate deploy",
    "db:migrate:dev": "zen migrate dev",
    "db:studio": "zen studio",
    "dev": "next dev --turbopack",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "prebuild": "zen generate && zen migrate deploy",
    "prepare": "husky",
    "start": "next start",
    "storybook": "storybook dev -p 6006",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui"
