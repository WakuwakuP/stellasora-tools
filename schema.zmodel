// ZenStack v3 schema for shortened URLs

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

/// 短縮URLモデル
/// ビルドデータの長いURLを短いコードに変換して保存
model ShortenedUrl {
    id          String   @id @default(cuid())
    /// 短縮コード（ランダム生成、ユニーク）
    code        String   @unique
    /// 元のURL（/build?... 形式のパスとクエリ部分）- 冪等性のためユニーク制約
    originalUrl String   @unique
    /// 作成日時
    createdAt   DateTime @default(now())

    @@index([code])
}
